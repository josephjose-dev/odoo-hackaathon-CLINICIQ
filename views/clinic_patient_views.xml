<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── List View ── -->
    <record id="clinic_patient_view_list" model="ir.ui.view">
        <field name="name">clinic.patient.list</field>
        <field name="model">clinic.patient</field>
        <field name="arch" type="xml">
            <list string="Patients"
                  decoration-danger="risk_level == 'critical'"
                  decoration-warning="risk_level == 'high'"
                  decoration-success="risk_level == 'low'"
                  decoration-info="overdue_checkup == True"
                  decoration-muted="state == 'inactive'">
                <field name="name"/>
                <field name="age"/>
                <field name="gender"/>
                <field name="phone"/>
                <field name="blood_type"/>
                <field name="risk_score" string="Risk Score"/>
                <field name="risk_level" string="Risk Level"/>
                <field name="overdue_checkup" string="Overdue"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- ── Form View ── -->
    <record id="clinic_patient_view_form" model="ir.ui.view">
        <field name="name">clinic.patient.form</field>
        <field name="model">clinic.patient</field>
        <field name="arch" type="xml">
            <form string="Patient">
                <header>
                    <button name="action_mark_critical"
                            string="Mark Critical"
                            type="object"
                            class="btn-danger"
                            invisible="state != 'active'"/>
                    <button name="action_mark_recovered"
                            string="Mark Recovered"
                            type="object"
                            class="btn-success"
                            invisible="state not in ('active', 'critical')"/>
                    <button name="action_mark_inactive"
                            string="Deactivate"
                            type="object"
                            invisible="state == 'inactive'"/>
                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="active,critical,recovered"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Personal Info">
                            <field name="date_of_birth"/>
                            <field name="age"/>
                            <field name="gender"/>
                            <field name="blood_type"/>
                            <field name="phone"/>
                            <field name="email"/>
                        </group>
                        <group string="Risk Assessment">
                            <field name="risk_score"/>
                            <field name="risk_level"/>
                            <field name="missed_appointments"/>
                            <field name="last_visit_days"/>
                            <field name="appointment_count"/>
                            <field name="overdue_checkup" string="⚠️ Overdue for Checkup"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Medical Info">
                            <group>
                                <field name="chronic_condition_ids" widget="many2many_tags"/>
                                <field name="allergy_ids" widget="many2many_tags"/>
                            </group>
                        </page>
                        <page string="Appointments">
                            <field name="appointment_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="appointment_date"/>
                                    <field name="doctor_name"/>
                                    <field name="state"/>
                                    <field name="no_show_probability"/>
                                </list>
                            </field>
                        </page>
                        <page string="Prescriptions">
                            <field name="prescription_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="prescription_date"/>
                                    <field name="doctor_name"/>
                                    <field name="state"/>
                                    <field name="has_allergy_conflict"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ── Action ── -->
    <record id="action_clinic_patient" model="ir.actions.act_window">
        <field name="name">Patients</field>
        <field name="res_model">clinic.patient</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>