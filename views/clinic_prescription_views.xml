<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── List View ── -->
    <record id="clinic_prescription_view_list" model="ir.ui.view">
        <field name="name">clinic.prescription.list</field>
        <field name="model">clinic.prescription</field>
        <field name="arch" type="xml">
            <list string="Prescriptions"
                  decoration-danger="has_allergy_conflict == True"
                  decoration-success="state == 'completed'"
                  decoration-muted="state == 'draft'">
                <field name="name"/>
                <field name="patient_id"/>
                <field name="doctor_name"/>
                <field name="prescription_date"/>
                <field name="has_allergy_conflict" string="Allergy Conflict"/>
                <field name="conflict_medicine_names" string="Conflicting Medicines"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- ── Form View ── -->
    <record id="clinic_prescription_view_form" model="ir.ui.view">
        <field name="name">clinic.prescription.form</field>
        <field name="model">clinic.prescription</field>
        <field name="arch" type="xml">
            <form string="Prescription">
                <header>
                    <button name="action_issue"
                            string="Issue Prescription"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_complete"
                            string="Mark Completed"
                            type="object"
                            class="btn-success"
                            invisible="state != 'issued'"/>
                    <button name="action_reset_draft"
                            string="Reset to Draft"
                            type="object"
                            invisible="state != 'issued'"/>
                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,issued,completed"/>
                </header>
                <sheet>
                    <!-- Allergy Warning Banner -->
                    <div class="alert alert-danger"
                         role="alert"
                         invisible="not has_allergy_conflict">
                        Allergy conflict detected:
                        <field name="conflict_medicine_names" readonly="True"/>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Prescription Info">
                            <field name="patient_id"/>
                            <field name="appointment_id"/>
                            <field name="doctor_name"/>
                            <field name="prescription_date"/>
                        </group>
                        <group string="Safety Check">
                            <field name="has_allergy_conflict"/>
                            <field name="conflict_medicine_names"
                                   invisible="not has_allergy_conflict"/>
                        </group>
                    </group>
                    <field name="line_ids">
                        <list editable="bottom">
                            <field name="medicine_id"/>
                            <field name="dosage"/>
                            <field name="frequency"/>
                            <field name="duration_days"/>
                            <field name="notes"/>
                        </list>
                    </field>
                    <field name="notes" placeholder="General instructions..."/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Action ── -->
    <record id="action_clinic_prescription" model="ir.actions.act_window">
        <field name="name">Prescriptions</field>
        <field name="res_model">clinic.prescription</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>