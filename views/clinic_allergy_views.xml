<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="clinic_allergy_view_list" model="ir.ui.view">
        <field name="name">clinic.allergy.list</field>
        <field name="model">clinic.allergy</field>
        <field name="arch" type="xml">
            <list string="Allergies">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="clinic_allergy_view_form" model="ir.ui.view">
        <field name="name">clinic.allergy.form</field>
        <field name="model">clinic.allergy</field>
        <field name="arch" type="xml">
            <form string="Allergy">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_clinic_allergy" model="ir.actions.act_window">
        <field name="name">Allergies</field>
        <field name="res_model">clinic.allergy</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
