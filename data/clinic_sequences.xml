<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="seq_clinic_appointment" model="ir.sequence">
        <field name="name">Clinic Appointment Sequence</field>
        <field name="code">clinic.appointment</field>
        <field name="prefix">APT/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_clinic_prescription" model="ir.sequence">
        <field name="name">Clinic Prescription Sequence</field>
        <field name="code">clinic.prescription</field>
        <field name="prefix">RX/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>

</odoo>
